<opml version="2.0">
    <head>
        <title>Miniflux</title>
        <dateCreated>Thu, 23 Apr 2026 00:55:26 -03</dateCreated>
    </head>
    <body>
        <outline text="Cibersecurity">
            <outline title="BleepingComputer" text="BleepingComputer" xmlUrl="https://www.bleepingcomputer.com/feed/" htmlUrl="https://www.bleepingcomputer.com" description="Full content. Cobertura rápida y técnica de incidentes, malware y vulnerabilidades." type="rss"></outline>
            <outline title="Cybersecurity News" text="Cybersecurity News" xmlUrl="https://cybersecuritynews.com/feed/" htmlUrl="https://cybersecuritynews.com" description="Full content. Noticias técnicas con buen detalle de PoC y exploits." type="rss"></outline>
            <outline title="Dark Reading" text="Dark Reading" xmlUrl="https://www.darkreading.com/rss.xml" htmlUrl="https://www.darkreading.com" description="Truncado — requiere fetch. Análisis de tendencias y ataques." type="rss"></outline>
            <outline title="Graham Cluley" text="Graham Cluley" xmlUrl="https://grahamcluley.com/feed/" htmlUrl="https://grahamcluley.com" description="Full content. Análisis accesible de incidentes y cibercrimen." type="rss"></outline>
            <outline title="Infosecurity Magazine" text="Infosecurity Magazine" xmlUrl="https://www.infosecurity-magazine.com/rss/news/" htmlUrl="https://www.infosecurity-magazine.com" description="Truncado — requiere fetch. Cobertura amplia de industria." type="rss"></outline>
            <outline title="Krebs on Security" text="Krebs on Security" xmlUrl="https://krebsonsecurity.com/feed/" htmlUrl="https://krebsonsecurity.com" description="Full content. Investigación periodística profunda sobre cibercrimen." type="rss"></outline>
            <outline title="Schneier on Security" text="Schneier on Security" xmlUrl="https://www.schneier.com/feed/atom/" htmlUrl="https://www.schneier.com" description="Full content. Análisis de política, criptografía y tendencias estratégicas." type="rss"></outline>
            <outline title="Security Affairs" text="Security Affairs" xmlUrl="https://securityaffairs.com/feed" htmlUrl="https://securityaffairs.com" description="Full content. Feed principal unificado (reemplaza las 7 categorías individuales)." type="rss"></outline>
            <outline title="SecurityWeek" text="SecurityWeek" xmlUrl="https://www.securityweek.com/feed/" htmlUrl="https://www.securityweek.com" description="Truncado — requiere fetch. Amplia cobertura de industria y vulnerabilidades." type="rss"></outline>
            <outline title="The Hacker News" text="The Hacker News" xmlUrl="https://feeds.feedburner.com/TheHackersNews" htmlUrl="https://thehackernews.com" description="Full content. Noticias técnicas diarias, CVEs y campañas activas." type="rss"></outline>
            <outline title="The Record by Recorded Future" text="The Record by Recorded Future" xmlUrl="https://therecord.media/feed" htmlUrl="https://therecord.media" description="Full content. Periodismo de threat intel con contexto geopolítico." type="rss"></outline>
        </outline>
        <outline text="Hacking &amp; Research">
            <outline title="Black Hills InfoSec" text="Black Hills InfoSec" xmlUrl="https://www.blackhillsinfosec.com/feed/" htmlUrl="https://www.blackhillsinfosec.com" description="Full content. Red team, pentesting y defensa activa." type="rss"></outline>
            <outline title="Exploit-DB" text="Exploit-DB" xmlUrl="https://www.exploit-db.com/rss.xml" htmlUrl="https://www.exploit-db.com" description="Solo títulos/metadatos — NO scrapear. PoC públicos: usar solo como señal de correlación CVE." type="rss"></outline>
            <outline title="Google Project Zero" text="Google Project Zero" xmlUrl="https://googleprojectzero.blogspot.com/feeds/posts/default" htmlUrl="https://googleprojectzero.blogspot.com" description="Full content. Investigación de vulnerabilidades de primer nivel." type="rss"></outline>
            <outline title="Huntress Blog" text="Huntress Blog" xmlUrl="https://www.huntress.com/blog/rss.xml" htmlUrl="https://www.huntress.com/blog" description="Full content. Análisis de malware y TTPs observadas en entornos reales." type="rss"></outline>
            <outline title="Outflank Research" text="Outflank Research" xmlUrl="https://outflank.nl/blog/feed/" htmlUrl="https://outflank.nl/blog" description="Full content. Red team, evasión de defensas y técnicas avanzadas." type="rss"></outline>
            <outline title="PortSwigger Web Security Blog" text="PortSwigger Web Security Blog" xmlUrl="https://portswigger.net/blog/rss" htmlUrl="https://portswigger.net/blog" description="Full content. Investigación web security, web cache attacks, etc." type="rss"></outline>
            <outline title="Sploitus" text="Sploitus" xmlUrl="https://sploitus.com/rss" htmlUrl="https://sploitus.com" description="Solo títulos — NO scrapear. Agrega exploits de múltiples fuentes, usar como señal de correlación." type="rss"></outline>
            <outline title="WatchTowr Labs" text="WatchTowr Labs" xmlUrl="https://labs.watchtowr.com/rss/" htmlUrl="https://labs.watchtowr.com" description="Full content. Research ofensivo de alta calidad técnica." type="rss"></outline>
        </outline>
        <outline text="LATAM">
            <outline title="CyberSecurity News ES" text="CyberSecurity News ES" xmlUrl="https://cybersecuritynews.es/feed/" htmlUrl="https://cybersecuritynews.es" description="Revista de ciberseguridad para España y LATAM." type="rss"></outline>
            <outline title="DragonJAR Security" text="DragonJAR Security" xmlUrl="https://www.dragonjar.org/feed" htmlUrl="https://www.dragonjar.org" description="Full content. Comunidad colombiana de seguridad, técnica y ofensiva." type="rss"></outline>
            <outline title="El Lado del Mal" text="El Lado del Mal" xmlUrl="https://www.elladodelmal.com/feeds/posts/default" htmlUrl="https://www.elladodelmal.com" description="Full content. Blog español técnico de Chema Alonso, muy activo y variado." type="rss"></outline>
            <outline title="ITware Latam - Ciberseguridad" text="ITware Latam - Ciberseguridad" xmlUrl="https://itwarelatam.com/category/corporativo/seguridad/ciberseguridad/feed/" htmlUrl="https://itwarelatam.com" description="Noticias IT corporativas de Latinoamérica con sección dedicada a ciberseguridad." type="rss"></outline>
            <outline title="Segu-Info" text="Segu-Info" xmlUrl="https://blog.segu-info.com.ar/feeds/posts/default" htmlUrl="https://blog.segu-info.com.ar" description="Full content. Blog argentino activo desde 2000, agrega noticias de seguridad en español." type="rss"></outline>
            <outline title="Una Al Día" text="Una Al Día" xmlUrl="https://unaaldia.hispasec.com/feed" htmlUrl="https://unaaldia.hispasec.com/" description="Boletín de noticias de Seguridad Informática ofrecido por Hispasec" type="rss"></outline>
        </outline>
        <outline text="Threat Intel">
            <outline title="Cisco Talos Intelligence" text="Cisco Talos Intelligence" xmlUrl="https://feeds.feedburner.com/feedburner/Talos" htmlUrl="https://blog.talosintelligence.com" description="Full content. Uno de los mejores equipos de threat intel del mundo." type="rss"></outline>
            <outline title="CrowdStrike Blog" text="CrowdStrike Blog" xmlUrl="https://www.crowdstrike.com/blog/feed/" htmlUrl="https://www.crowdstrike.com/en-us/blog/" description="Full content. Tracking de adversarios nombrados (BEAR/PANDA/SPIDER). Global Threat Report, inteligencia de primera línea." type="rss"></outline>
            <outline title="Elastic Security Labs" text="Elastic Security Labs" xmlUrl="https://www.elastic.co/security-labs/rss/feed.xml" htmlUrl="https://www.elastic.co/security-labs" description="Full content. Análisis de malware con YARA, detecciones conductuales. 40+ investigadores, alto rigor técnico." type="rss"></outline>
            <outline title="Google TAG (Threat Analysis Group)" text="Google TAG (Threat Analysis Group)" xmlUrl="https://blog.google/threat-analysis-group/rss/" htmlUrl="https://blog.google/threat-analysis-group/" description="Full content. Seguimiento de actores respaldados por estados (APTs gubernamentales, spyware). Perspectiva única de Google." type="rss"></outline>
            <outline title="Kaspersky Securelist" text="Kaspersky Securelist" xmlUrl="https://securelist.com/feed/" htmlUrl="https://securelist.com" description="Full content. Investigación técnica de malware y APTs." type="rss"></outline>
            <outline title="Malwarebytes Labs" text="Malwarebytes Labs" xmlUrl="https://blog.malwarebytes.com/feed/" htmlUrl="https://blog.malwarebytes.com" description="Full content. Análisis de malware y amenazas consumer/SMB." type="rss"></outline>
            <outline title="Mandiant Blog" text="Mandiant Blog" xmlUrl="https://www.mandiant.com/resources/blog/rss.xml" htmlUrl="https://www.mandiant.com" description="Full content. APT tracking, incident response y attribution." type="rss"></outline>
            <outline title="Microsoft Security Blog" text="Microsoft Security Blog" xmlUrl="https://www.microsoft.com/en-us/security/blog/feed/" htmlUrl="https://www.microsoft.com/en-us/security/blog" description="Full content. MSTIC threat intel, Defender y noticias de seguridad MS." type="rss"></outline>
            <outline title="Palo Alto Unit 42" text="Palo Alto Unit 42" xmlUrl="https://unit42.paloaltonetworks.com/feed/" htmlUrl="https://unit42.paloaltonetworks.com" description="Full content. Análisis técnico profundo de amenazas y campañas." type="rss"></outline>
            <outline title="Proofpoint Threat Insight" text="Proofpoint Threat Insight" xmlUrl="https://www.proofpoint.com/us/rss.xml" htmlUrl="https://www.proofpoint.com/us/blog/threat-insight" description="Full content. Amenazas por email, actores TA-numerados (TA505, TA577). Phishing, BEC y malware distribuido por correo." type="rss"></outline>
            <outline title="Recorded Future Blog" text="Recorded Future Blog" xmlUrl="https://www.recordedfuture.com/feed" htmlUrl="https://www.recordedfuture.com/blog" description="Full content. Threat intel estratégica con contexto geopolítico." type="rss"></outline>
            <outline title="SANS Internet Storm Center" text="SANS Internet Storm Center" xmlUrl="https://isc.sans.edu/rssfeed_full.xml" htmlUrl="https://isc.sans.edu" description="Full content (feed_full). Diarios técnicos y alertas de internet." type="rss"></outline>
            <outline title="SentinelOne Blog" text="SentinelOne Blog" xmlUrl="https://www.sentinelone.com/blog/feed/" htmlUrl="https://www.sentinelone.com/blog" description="Full content. Research técnico de malware y amenazas avanzadas." type="rss"></outline>
            <outline title="Sophos News" text="Sophos News" xmlUrl="https://www.sophos.com/es-es/blog/feed?id=blt6f15f4f7deaf4242" htmlUrl="https://news.sophos.com" description="Full content. Análisis técnico de ransomware y amenazas activas. Incluye contenido ex-Secureworks CTU." type="rss"></outline>
            <outline title="The DFIR Report" text="The DFIR Report" xmlUrl="https://thedfirreport.com/feed/" htmlUrl="https://thedfirreport.com" description="Full content. Reportes forenses detallados de intrusiones reales." type="rss"></outline>
            <outline title="tl;dr sec Newsletter" text="tl;dr sec Newsletter" xmlUrl="https://tldrsec.com/feed.xml" htmlUrl="https://tldrsec.com" description="Full content. Digest semanal curado — excelente señal/ruido." type="rss"></outline>
            <outline title="Wiz Research Blog" text="Wiz Research Blog" xmlUrl="https://www.wiz.io/blog/rss" htmlUrl="https://www.wiz.io/blog" description="Full content. Cloud security research, misconfigs críticas y CVEs cloud." type="rss"></outline>
        </outline>
        <outline text="Vulnerability">
            <outline title="AWS Security Bulletins" text="AWS Security Bulletins" xmlUrl="https://aws.amazon.com/security/security-bulletins/rss/feed/" htmlUrl="https://aws.amazon.com/security/security-bulletins" description="Boletines oficiales de AWS. Bajo volumen, alta relevancia para entornos cloud." type="rss"></outline>
            <outline title="CERT/CC Vulnerabilities" text="CERT/CC Vulnerabilities" xmlUrl="https://www.kb.cert.org/vulfeed/" htmlUrl="https://www.kb.cert.org" description="Vulnerabilidades coordinadas por CERT/CC con análisis técnico." type="rss"></outline>
            <outline title="CISA Advisories" text="CISA Advisories" xmlUrl="https://www.cisa.gov/cybersecurity-advisories/all.xml" htmlUrl="https://www.cisa.gov" description="Oficial US-CERT. KEV, ICS advisories y alertas gubernamentales. Incluye vulnerabilidades explotadas activamente." type="rss"></outline>
            <outline title="Full Disclosure" text="Full Disclosure" xmlUrl="https://seclists.org/rss/fulldisclosure.rss" htmlUrl="https://seclists.org/fulldisclosure" description="Solo títulos — requiere fetch. Divulgación pública de vulnerabilidades." type="rss"></outline>
            <outline title="GitHub Security" text="GitHub Security" xmlUrl="https://github.blog/security/feed/" htmlUrl="https://github.blog/security" description="Full content. Vulnerabilidades en supply chain y ecosistema open source." type="rss"></outline>
            <outline title="MSRC Security Update Guide" text="MSRC Security Update Guide" xmlUrl="https://api.msrc.microsoft.com/update-guide/rss" htmlUrl="https://msrc.microsoft.com/update-guide/" description="Boletines de seguridad de Microsoft. Muy alto volumen (2975 entradas) — requiere filtro CVSS antes de Stage 2." type="rss"></outline>
            <outline title="Qualys Security Blog" text="Qualys Security Blog" xmlUrl="https://blog.qualys.com/feed" htmlUrl="https://blog.qualys.com" description="Full content. Análisis técnico de vulnerabilidades con contexto de remediación." type="rss"></outline>
            <outline title="Rapid7 Blog" text="Rapid7 Blog" xmlUrl="https://blog.rapid7.com/rss/" htmlUrl="https://blog.rapid7.com" description="Full content. Análisis de vulnerabilidades, Metasploit y threat intel." type="rss"></outline>
            <outline title="Red Hat Security" text="Red Hat Security" xmlUrl="https://www.redhat.com/en/rss/blog/channel/security" htmlUrl="https://www.redhat.com/en/blog/channel/security" description="Full content. CVEs en Linux, kernel y ecosistema open source." type="rss"></outline>
            <outline title="Tenable Security Research" text="Tenable Security Research" xmlUrl="https://www.tenable.com/security/research/feed" htmlUrl="https://www.tenable.com/security/research" description="Full content. Análisis técnico de CVEs con contexto de exploitabilidad real. Complementa CVSS con evaluación de riesgo práctico." type="rss"></outline>
            <outline title="Vulners" text="Vulners" xmlUrl="https://vulners.com/rss.xml" htmlUrl="https://vulners.com" description="Solo títulos — URLs bloqueadas (403). NO scrapear. Usar como señal de correlación con el título solamente." type="rss"></outline>
            <outline title="Zero Day Initiative (ZDI) — Published" text="Zero Day Initiative (ZDI) — Published" xmlUrl="https://www.zerodayinitiative.com/rss/published/" htmlUrl="https://www.zerodayinitiative.com/advisories/published/" description="Solo metadatos — NO scrapear. Advisory IDs, CVEs y affected vendor/product. Programa de bug bounty de Trend Micro: alertas tempranas de 0-days antes del parche del vendor." type="rss"></outline>
        </outline>
    </body>
