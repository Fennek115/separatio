        <!-- ════════════════════════════════════════════
             VULNERABILITY — CVEs, advisories y boletines
             ════════════════════════════════════════════ -->
        <outline text="Vulnerability">
            <outline title="CISA Advisories" text="CISA Advisories"
                xmlUrl="https://www.cisa.gov/cybersecurity-advisories/all.xml"
                htmlUrl="https://www.cisa.gov" type="rss"
                description="Oficial US-CERT. KEV, ICS advisories y alertas gubernamentales. Incluye vulnerabilidades explotadas activamente." />

            <outline title="NVD - National Vulnerability Database" text="NVD - National Vulnerability Database"
                xmlUrl="https://nvd.nist.gov/feeds/xml/cve/misc/nvd-rss.xml"
                htmlUrl="https://nvd.nist.gov" type="rss"
                description="CVEs recientes con CVSS. Alto volumen — filtrar por severidad ≥7 antes de Stage 2 (pendiente implementar)." />

            <outline title="MSRC Security Update Guide" text="MSRC Security Update Guide"
                xmlUrl="https://api.msrc.microsoft.com/update-guide/rss"
                htmlUrl="https://msrc.microsoft.com/update-guide/" type="rss"
                description="Boletines de seguridad de Microsoft. Muy alto volumen (2975 entradas) — requiere filtro CVSS antes de Stage 2." />

            <outline title="CERT/CC Vulnerabilities" text="CERT/CC Vulnerabilities"
                xmlUrl="https://www.kb.cert.org/vulfeed/"
                htmlUrl="https://www.kb.cert.org" type="rss"
